# Copy this to .env for LOCAL testing only. Do NOT commit your real .env.
# On GitHub, set these as Secrets/Variables instead (see README).

# "always" = alert every run | "switch_only" = alert only on SWITCH/ENTER
ALERT_MODE=always

# ---------- Email (Gmail example) ----------
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_16_char_app_password   # Gmail App Password, NOT your login password
EMAIL_TO=youremail@gmail.com

# ---------- Telegram ----------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456789:ABCdef_your_bot_token_from_BotFather
TELEGRAM_CHAT_ID=123456789
